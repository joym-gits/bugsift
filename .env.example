# =============================================================================
# bugsift — environment variables
# =============================================================================
# Copy this file to `.env` and fill in the values. The `.env` file is
# gitignored; never commit real secrets. Every variable below is required
# unless marked (optional).
#
# For a fresh local setup you can leave most of the GitHub App variables blank
# until Phase 3 lands; the Phase 1 stack only needs the database/Redis and
# BUGSIFT_ENCRYPTION_KEY.
# =============================================================================

# ----- Core -----------------------------------------------------------------
# Environment name. One of: development, production.
BUGSIFT_ENV=development

# Public origin the dashboard is served from. Used for CORS and callback URLs.
BUGSIFT_PUBLIC_URL=http://localhost:8080

# Fernet key used to encrypt user LLM API keys at rest.
# Generate once with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
BUGSIFT_ENCRYPTION_KEY=

# Session-signing secret used by the dashboard backend. Any long random string.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
BUGSIFT_SESSION_SECRET=

# Bootstrap token — required for the first-run GitHub App registration in
# production. Prevents a drive-by visitor to a pre-onboarding deployment from
# claiming the instance. Blank = dev mode (onboarding is open on localhost).
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
BUGSIFT_BOOTSTRAP_TOKEN=

# Trust nginx's X-Real-IP header for rate-limit keying. Leave "1" for the
# bundled docker-compose stack (nginx is the only peer the backend ever sees).
# Set to "0" only if you expose backend directly, with no proxy in front.
BUGSIFT_TRUST_PROXY=1

# ----- Database -------------------------------------------------------------
POSTGRES_USER=bugsift
POSTGRES_PASSWORD=bugsift
POSTGRES_DB=bugsift
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SQLAlchemy URL, derived from the above. Override only if you are not using
# the bundled Postgres container.
DATABASE_URL=postgresql+asyncpg://bugsift:bugsift@postgres:5432/bugsift

# ----- Redis / queue --------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ----- GitHub App (Phase 3+) ------------------------------------------------
# Register a GitHub App following docs/installation.md, then fill these in.
# Until Phase 3 lands these can stay blank.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_WEBHOOK_SECRET=
# Private key PEM, either inline (as a single-line string with \n escaped) or
# a path on disk readable by the backend container. Pick one.
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_PRIVATE_KEY_PATH=

# ----- Frontend -------------------------------------------------------------
# Public URL the browser uses to reach the backend API. Through the bundled
# nginx reverse proxy this is the same origin as BUGSIFT_PUBLIC_URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080/api

# ----- LLM defaults (optional) ---------------------------------------------
# Per-user keys are stored encrypted in the database. These variables are only
# used for the backend's own integration tests and can be left blank in normal
# operation.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434
